# Optional SMTP settings for sending real email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=Barcode Payment App <no-reply@example.com>

# Optional Twilio SMS settings
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Optional JWT secret for production
JWT_SECRET=replace-this-with-a-secure-secret
CLIENT_ORIGIN=http://127.0.0.1:8000
